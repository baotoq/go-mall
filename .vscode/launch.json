{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/src/storefront",
      "env": {
        "NODE_OPTIONS": "--inspect"
      }
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "cwd": "${workspaceFolder}/src/storefront",
      "url": "http://localhost:3000"
    },
    {
      "name": "Next.js: debug full stack",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/storefront/node_modules/next/dist/bin/next",
      "args": ["dev"],
      "runtimeArgs": ["--inspect"],
      "cwd": "${workspaceFolder}/src/storefront",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/src/storefront"
      }
    },
    {
      "name": "Go: attach catalog-api",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "localhost",
      "port": 40001
    },
    {
      "name": "Go: attach cart-api",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "localhost",
      "port": 40002
    },
    {
      "name": "Go: attach payment-api",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "localhost",
      "port": 40003
    }
  ]
}
